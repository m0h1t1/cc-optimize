{
  "manifest_version": 3,
  "name": "MoPay — Credit Card Optimizer",
  "version": "1.0.0",
  "description": "Automatically recommends the best credit card to maximize rewards at checkout.",
  "permissions": ["storage", "activeTab", "tabs"],
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "MoPay"
  },
  "icons": {}
}
